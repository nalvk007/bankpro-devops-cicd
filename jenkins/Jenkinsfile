pipeline {
    agent any

    stages {

        stage('Build') {
            steps {
                dir('app') {
                    sh 'mvn clean package'
                }
            }
        }

	stage('Docker Build') {
    	    steps {
        	sh 'docker build -t bankpro-app -f docker/Dockerfile .'
    	    }
        }

	stage('Docker Info') {
    	    steps {
        	sh 'whoami'
        	sh 'docker version'
        	sh 'docker ps'
    	    }
	}

	stage('Generate Inventory') {
    	    steps {
        	sh '''
        	echo "[aws]" > ansible/inventory.ini
        	echo "ec2-instance ansible_host=${EC2_IP} ansible_user=ec2-user ansible_ssh_private_key_file=/var/lib/jenkins/.ssh/key.pem" >> ansible/inventory.ini
        	cat ansible/inventory.ini
        	'''
    	    }
	}
        
        stage('Deploy via Ansible') {
            steps {
                sh 'ansible-playbook -i ansible/inventory.ini ansible/deploy.yml'
            }
        }
    }
}
